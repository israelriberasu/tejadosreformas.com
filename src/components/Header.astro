---
/**
 * Header — Main site navigation (sticky top bar)
 * TejadosReformas Burgos
 *
 * Mobile: hamburger toggle menu
 * Desktop: horizontal nav links
 */

interface Props {
  /** Optional override for the logo link label */
  logoSrOnly?: string;
}

const { logoSrOnly = 'Ir al inicio' } = Astro.props;

const navLinks = [
  { href: '#hero', label: 'Inicio' },
  { href: '#roofing-services', label: 'Tejados' },
  { href: '#multi-services', label: 'Reformas' },
  { href: '#trust-values', label: 'Confianza' },
  { href: '#testimonials', label: 'Testimonios' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contacto' },
];
---

<header class="header">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="#hero" class="header__logo" aria-label={logoSrOnly}>
      <span class="header__logo-primary">Tejados</span><span>Reformas</span>
    </a>

    <!-- Desktop navigation -->
    <nav class="nav-menu" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <!-- Mobile hamburger button -->
    <button
      class="nav-toggle"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height);
    background-color: var(--color-bg);
    box-shadow: var(--shadow-sm);
    z-index: 1000;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header__logo {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header__logo:hover {
    color: var(--color-primary);
  }

  .header__logo-primary {
    color: var(--color-accent);
  }

  /* Nav links desktop overrides */
  .nav-link {
    font-size: 0.9375rem !important;
    font-weight: 500 !important;
    color: var(--color-text) !important;
    padding: 0.375rem 0.75rem !important;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-accent) !important;
    background-color: rgba(228, 121, 35, 0.06);
  }

  /* Ensure nav-menu from global.css works responsively */
  :global(.nav-menu) {
    /* Inherits from global.css — only override if needed */
  }

  @media (max-width: 767px) {
    .header__logo {
      font-size: 1.125rem;
    }
  }

  /* Push page content below fixed header */
  :global(body) {
    padding-top: var(--header-height);
  }
</style>

<script>
  /**
   * Sync aria-expanded attribute on nav-toggle when menu toggles.
   * This runs on each page navigation (astro:page-load) for View Transitions.
   */
  function syncAriaExpanded() {
    const toggle = document.querySelector('.nav-toggle');
    const menu = document.querySelector('.nav-menu');
    if (!toggle || !menu) return;

    const observer = new MutationObserver(function () {
      const isActive = menu.classList.contains('is-active');
      toggle.setAttribute('aria-expanded', isActive ? 'true' : 'false');
      toggle.setAttribute('aria-label', isActive ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
    });

    observer.observe(menu, { attributes: true, attributeFilter: ['class'] });
  }

  // Run on initial load and after each View Transition
  document.addEventListener('astro:page-load', syncAriaExpanded);
  syncAriaExpanded();
</script>
