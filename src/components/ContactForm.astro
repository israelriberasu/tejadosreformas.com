<!-- ContactForm.astro — Solicita tu presupuesto gratis -->

<section id="contact" class="section contact">
  <div class="container">
    <header class="contact__header">
      <h2>Solicita tu Presupuesto Gratis en 24 Horas</h2>
      <p class="contact__intro">
        Rellena el formulario y nos pondremos en contacto contigo para ofrecerte un
        presupuesto detallado sin compromiso.
      </p>
    </header>

    <!--
      ════════════════════════════════════════════════════════
      IMPORTANTE: Reemplaza "REEMPLAZAR_CON_TU_FORM_ID" con
      tu ID real de Formspree para que el formulario funcione.
      Ejemplo: https://formspree.io/f/xyzkab123
      ════════════════════════════════════════════════════════
    -->
    <form class="contact__form" action="https://formspree.io/f/REEMPLAZAR_CON_TU_FORM_ID" method="POST">
      <div class="contact__field">
        <label for="name">Nombre completo *</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Ej: Juan García López"
          required
          autocomplete="name"
        />
      </div>

      <div class="contact__field">
        <label for="phone">Teléfono de contacto *</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="Ej: 622 299 746"
          required
          autocomplete="tel"
          pattern="[0-9\s\+]{9,15}"
        />
      </div>

      <div class="contact__field">
        <label for="location">Localización del trabajo *</label>
        <input
          type="text"
          id="location"
          name="location"
          placeholder="Burgos Capital / Provincia"
          required
        />
      </div>

      <div class="contact__field">
        <label for="service">Tipo de Servicio *</label>
        <select id="service" name="service" required>
          <option value="" disabled selected>Selecciona un servicio</option>
          <option value="tejados">Tejados</option>
          <option value="reformas">Reformas</option>
          <option value="manitas">Manitas</option>
          <option value="fontaneria-electricidad">Fontanería o Electricidad</option>
        </select>
      </div>

      <div class="contact__field contact__field--full">
        <label for="message">Mensaje / Detalles del proyecto</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Describe brevemente el trabajo que necesitas..."
        ></textarea>
      </div>

      <div class="contact__action">
        <button type="submit" class="btn-submit">
          Enviar Solicitud de Presupuesto
        </button>
      </div>
    </form>
  </div>
</section>

<style>
  /* ---- Contact Form ---- */
  .contact {
    background-color: var(--color-bg-alt, #f8f9fa);
  }

  .contact__header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 2.5rem;
  }

  .contact__intro {
    font-size: 1.05rem;
    color: var(--color-text-light, #555);
    line-height: 1.7;
  }

  /* ---- Form ---- */
  .contact__form {
    max-width: 640px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    background-color: #ffffff;
    padding: 2.5rem;
    border-radius: var(--border-radius, 8px);
    box-shadow: var(--shadow-md, 0 4px 16px rgba(0, 0, 0, 0.1));
  }

  @media (min-width: 600px) {
    .contact__form {
      grid-template-columns: 1fr 1fr;
    }

    .contact__field--full {
      grid-column: 1 / -1;
    }

    .contact__action {
      grid-column: 1 / -1;
    }
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .contact__field label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary, #1a3254);
  }

  .contact__field input,
  .contact__field select,
  .contact__field textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border, #e0e0e0);
    border-radius: var(--border-radius, 8px);
    font-family: var(--font-family);
    font-size: 0.95rem;
    color: var(--color-text, #1a1a1a);
    background-color: #ffffff;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
    outline: none;
    width: 100%;
  }

  .contact__field input:focus,
  .contact__field select:focus,
  .contact__field textarea:focus {
    border-color: var(--color-accent, #e47923);
    box-shadow: 0 0 0 3px rgba(228, 121, 35, 0.15);
  }

  .contact__field input::placeholder,
  .contact__field textarea::placeholder {
    color: #999;
  }

  .contact__field input:user-invalid,
  .contact__field select:user-invalid {
    border-color: #d32f2f;
  }

  .contact__field textarea {
    resize: vertical;
    min-height: 100px;
  }

  .contact__action {
    margin-top: 0.5rem;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 1rem 2rem;
    border: none;
    border-radius: var(--border-radius, 8px);
    background-color: var(--color-accent, #e47923);
    color: #ffffff;
    font-size: 1.05rem;
    font-weight: 700;
    font-family: var(--font-family);
    cursor: pointer;
    transition:
      background-color 0.25s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .btn-submit:hover {
    background-color: #d06a1a;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(228, 121, 35, 0.30);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  @media (max-width: 600px) {
    .contact__form {
      padding: 1.5rem;
    }

    .contact__header {
      margin-bottom: 2rem;
    }
  }
</style>
